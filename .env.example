# ============================================================
# RevTry — Revenue Operations Sentry
# Environment Variables
# ============================================================

# === Required: GoHighLevel ===
GHL_API_KEY=
GHL_PROD_API_KEY=
GHL_BASE_URL=https://services.leadconnectorhq.com
GHL_LOCATION_ID=
GHL_CALENDAR_ID=

# === Required: Apollo.io (Phase 1 — lead discovery + enrichment) ===
APOLLO_API_KEY=

# === Deferred: Enrichment Fallbacks (uncomment when activated) ===
# BETTERCONTACT_API_KEY=
# CLAY_API_KEY=

# === Paths ===
# Vault lives in the runtime workspace — update this to your actual path
VAULT_DIR=e:/CAIO RevOps Claw/revtry/vault
OUTPUTS_DIR=outputs
REGISTRY_DIR=e:/CAIO RevOps Claw/revtry/registry

# === Phase 2: Outreach Dispatch ===
INSTANTLY_API_KEY=
INSTANTLY_FROM_EMAIL=
HEYREACH_API_KEY=
HEYREACH_CAMPAIGN_ID=
DISPATCH_DAILY_LIMIT=5
DISPATCH_TIER_RESTRICTION=1

# === Feature Flags ===
FEEDBACK_LOOP_POLICY_ENABLED=false
