# ============================================================
# RevTry — Revenue Operations Sentry
# Environment Variables
# ============================================================

# === Required: GoHighLevel ===
GHL_API_KEY=
GHL_PROD_API_KEY=
GHL_BASE_URL=https://services.leadconnectorhq.com
GHL_LOCATION_ID=
GHL_CALENDAR_ID=

# === Required: Apollo.io (Phase 1 — lead discovery + enrichment) ===
APOLLO_API_KEY=

# === Deferred: Enrichment Fallbacks (uncomment when activated) ===
# BETTERCONTACT_API_KEY=
# CLAY_API_KEY=

# === Paths ===
# Vault lives in the runtime workspace — update this to your actual path
VAULT_DIR=e:/CAIO RevOps Claw/revtry/vault
OUTPUTS_DIR=outputs
REGISTRY_DIR=e:/CAIO RevOps Claw/revtry/registry

# === Phase 2: Outreach Dispatch (GHL warm email) ===
GHL_FROM_EMAIL=chris@chiefaiofficer.com
GHL_FROM_NAME=Chris
# Temporary same-day warm dispatch override. Default ramp policy remains 5/day unless explicitly overridden.
DISPATCH_DAILY_LIMIT=5
DISPATCH_TIER_RESTRICTION=1

# === Phase 3: Warm Follow-Up System ===
ANTHROPIC_API_KEY=
DAILY_SCAN_BATCH_SIZE=50
FOLLOWUP_SCAN_DAYS=90
SCHEDULER_ENABLED=false
SCHEDULER_TIMEZONE=America/Chicago
DASHBOARD_AUTH_ENABLED=false
DASHBOARD_BASIC_AUTH_USER=
DASHBOARD_BASIC_AUTH_PASS=
STORAGE_BACKEND=file
DATABASE_URL=
WARM_ONLY_MODE=false
# Deprecated transitional alias only. Use DAILY_SCAN_BATCH_SIZE instead.
# MAX_SCAN_CONTACTS=50

# === Deferred: Cold Email + LinkedIn (uncomment when activated) ===
# INSTANTLY_API_KEY=
# INSTANTLY_FROM_EMAIL=
# HEYREACH_API_KEY=
# HEYREACH_CAMPAIGN_ID=

# === Feature Flags ===
FEEDBACK_LOOP_POLICY_ENABLED=false
